# Application Configuration
APP_NAME="AI QA Service"
APP_ENV="development"
API_V1_STR="/api/v1"

# Use sqlite+aiosqlite for local testing, or postgresql+asyncpg for Postgres pgvector connection
DATABASE_URL="sqlite+aiosqlite:///./local_dev.db"
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/ai_qa_db"


# Security (Placeholder for JWT, CORS, etc.)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
PROJECT_SECRET_KEY="super-secret-key-for-development"

# OpenAI LLM Configuration
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4o-mini"

